# Copy to `.env` and fill in values as needed for local development.
# Keys are optional unless you exercise live Google/Anthropic APIs.

# Google AI / Gemini (ADK agents)
GOOGLE_API_KEY=

# Optional: Vertex AI / Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: Anthropic API (integrations extra)
ANTHROPIC_API_KEY=
